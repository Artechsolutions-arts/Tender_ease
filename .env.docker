# ═══════════════════════════════════════════════════════
#  AP e-Procurement — Docker environment configuration
#  Copy this to .env and fill in the values below.
#  Then run:  docker compose up --build
# ═══════════════════════════════════════════════════════

# ── REQUIRED: Anthropic API key for AI features ─────────────────────────────
ANTHROPIC_API_KEY=sk-ant-

# ── Server port (default: 80) ─────────────────────────────────────────────
APP_PORT=80

# ── Secrets — change these before deploying to production ────────────────
POSTGRES_PASSWORD=apGov@2024!
JWT_SECRET=AP_eProcure_JWT_Secret_Change_This_In_Production
JWT_REFRESH_SECRET=AP_eProcure_Refresh_Change_This_In_Production

# ── SMTP Email (optional — emails are logged to console if not set) ───────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=AP e-Procurement <noreply@apeprocurement.gov.in>
