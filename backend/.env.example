# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:password@localhost:5432/ap_eprocurement"

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET="change-this-to-a-long-random-secret-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="change-this-refresh-secret-too"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
FRONTEND_URL="http://localhost:8080"

# ─── Anthropic Claude AI ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="noreply@apeprocurement.gov.in"
SMTP_PASS="your-app-password"
SMTP_FROM="AP e-Procurement <noreply@apeprocurement.gov.in>"
